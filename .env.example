# Database (Neon serverless Postgres)
# Get from: https://console.neon.tech → your project → Connection string
# Use the "pooled" connection string for the app, "direct" for Alembic migrations
DATABASE_URL=postgresql+psycopg2://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Stripe
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (email)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# Anthropic (AI follow-up generation)
# Get from: https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=sk-ant-...

# Clerk (auth)
# Get from: https://dashboard.clerk.com → your app → API Keys
CLERK_SECRET_KEY=sk_test_...
# JWKS URL: https://<your-clerk-domain>/.well-known/jwks.json
# Find your Clerk domain in Dashboard → API Keys → "Clerk domain"
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json

# Frontend URL (used for payment link generation and CORS)
FRONTEND_URL=http://localhost:5173
